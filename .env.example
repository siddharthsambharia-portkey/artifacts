# Artifact environment variables. Copy to .env and fill in for your deployment.
# All values below are placeholders — never commit real secrets.

# --- Secrets (referenced by *_env keys in artifact.yaml) ---
ARTIFACT_OIDC_SECRET=changeme-oidc-client-secret      # auth.oidc.client_secret_env
ARTIFACT_PROXY_SECRET=changeme-proxy-shared-secret    # auth.header_trust.proxy_secret_env (required for header-trust mode)
ARTIFACT_AI_KEY=changeme-ai-upstream-api-key          # ai.api_key_env
ARTIFACT_WAREHOUSE_CREDS=changeme-warehouse-creds     # warehouse.credentials_env (JSON or DSN, driver-dependent)
ARTIFACT_SLACK_SECRET=changeme-slack-webhook-or-token # notify.slack.secret_env

# --- Database ---
ARTIFACT_DATABASE_URL=postgres://user:pass@localhost:5432/artifact?sslmode=disable  # database.url_env (overrides database.url)

# --- Direct config overrides (optional; take precedence over artifact.yaml) ---
ARTIFACT_CONFIG=./artifact.yaml      # path to the config file to load
ARTIFACT_DOMAIN=artifact.corp.example.com  # base domain for subdomain routing
ARTIFACT_LISTEN=:8443                # listen address
ARTIFACT_AUTH_MODE=dev               # dev | oidc | header-trust
ARTIFACT_STORAGE_DRIVER=local        # local | s3 | gcs
ARTIFACT_DATA_DIR=.artifact-data     # local data/storage directory
ARTIFACT_GOVERNANCE_MODE=trust       # trust | governed
